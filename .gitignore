# Python bytecode cache.
__pycache__/

# Local docker-compose secrets — never commit. (.env.example is the template.)
.env

# Local docker-compose overrides — host-specific testing accommodations,
# never committed. The committed docker-compose.yml is the deployment shape.
docker-compose.override.yml

# Ignore .claude settings
.claude

# hone-core DB/identity backups produced by core/scripts/backup.sh —
# local operational artifacts, never committed.
core/backups/

# hone-node simulator data dir (scripts/run-node-sim.sh)
.sim/

# Generated dev-metrics report — regenerate with reports/dev-metrics-pdf.py.
reports/dev-metrics.jsonl
reports/dev-metrics.pdf

# Local scratch data (downloaded mboxes, test inputs) — never committed.
data/
