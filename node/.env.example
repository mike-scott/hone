# hone-node — environment template.  cd node && cp .env.example .env
# .env is gitignored — never commit real secrets.
#
# A node starts from scratch given only these four settings.

# URL of the hone-core service this node connects to.
HONE_CORE_URL=

# Shared fleet secret — must match hone-core's HONE_FLEET_SECRET.
HONE_FLEET_SECRET=

# Client key — this node's tenant identity. Register a client on hone-core
# (admin POST /v1/clients) and paste the returned key here.
HONE_CLIENT_KEY=

# The AI API token this node uses for its reviews (the Anthropic API key).
ANTHROPIC_API_KEY=
