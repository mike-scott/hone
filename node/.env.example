# hone-node — environment template.  cd node && cp .env.example .env
# .env is gitignored — never commit real secrets.
#
# A node starts from scratch given only these three settings. On first start
# it enrolls into the fleet via the device-authorization grant: it logs a user
# code for an operator to approve in hone-core's web UI (ARCHITECTURE.md →
# Auth, enrollment & transport). Its bearer tokens and hone-core's CA
# certificate are then persisted to the data volume and reused on restart.

# URL of the hone-core service this node connects to (https://...).
HONE_CORE_URL=

# Shared fleet secret — must match hone-core's HONE_FLEET_SECRET. It gates the
# enrollment (OAuth) API only; the node authenticates everything else with the
# bearer token it obtains by enrolling.
HONE_FLEET_SECRET=

# Which Claude backend the node uses for its reviews:
#   cli  — subprocess the `claude` CLI binary (default), using whatever OAuth
#          session lives under $HOME/.claude. Intended for Claude Code
#          subscribers without API billing. Requires uncommenting the
#          bind-mount in docker-compose.yml so the container can read
#          the host's ~/.claude — see docs/DEPLOYMENT.md.
#   sdk  — the Anthropic Python SDK. Requires API billing on
#          console.anthropic.com and ANTHROPIC_API_KEY below.
HONE_CLAUDE_BACKEND=cli

# Settings for `claude` CLI to point at a different BASE_URL and/or use
# and AUTH_TOKEN for enterprise uses.  Required when HONE_CLAUDE_BACKEND=cli
# Depending on whether the node maps a host ~/.claude dir or uses proxy.
# ANTHROPIC_BASE_URL=
# ANTHROPIC_AUTH_TOKEN=

# The AI API token this node uses for its reviews (the Anthropic API key).
# Required when HONE_CLAUDE_BACKEND=sdk. Ignored when =cli (the CLI binary
# authenticates via OAuth, no key needed here).
ANTHROPIC_API_KEY=

# Optional — Claude model id to use for every operation. Passed to the
# `claude` CLI via --model, or to the Anthropic SDK as `model=`.
# Defaults to the value of DEFAULT_MODEL in node/ai.py when unset.
# ANTHROPIC_MODEL=anthropic::claude-sonnet-4-6:1M

# Optional — a label for this node, shown to the operator at approval.
# Defaults to the container hostname.
# HONE_NODE_NAME=

# Optional — log level (DEBUG / INFO / WARNING / ERROR). Default INFO.
# Flip to DEBUG to see the full Claude prompts + responses (CLI
# backend) and per-tick health snapshots. Container log gets noisy
# at DEBUG; keep it off in production.
# HONE_LOG_LEVEL=DEBUG

# UID/GID the `hone` user inside the container runs as. Default
# 1000/1000 — matches the first interactive user on most Linux
# distros, so bind-mounting host directories (e.g. ~/.claude for
# HONE_CLAUDE_BACKEND=cli) works without files ending up owned by
# root. Match these to your host user via `id -u` / `id -g` if it
# differs. Both are baked in at build time — change them and
# rebuild (`docker compose up --build`).
# HONE_CLAUDE_CLI_USER=1000
# HONE_CLAUDE_CLI_GROUP=1000
