# hone-core — environment template.  cd core && cp .env.example .env
# .env is gitignored — never commit real secrets.

# Shared fleet secret — the coarse node<->core transport gate. hone-core and
# every hone-node must use the SAME value.   generate:  openssl rand -hex 32
HONE_FLEET_SECRET=example

# Admin token — authenticates the admin API (registering clients, etc.).
# generate:  openssl rand -hex 32
HONE_ADMIN_TOKEN=demo

# Host port to publish hone-core on (optional; default 8000).
HONE_HTTP_PORT=8000
