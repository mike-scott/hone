# hone-core — environment template.  cd core && cp .env.example .env
# .env is gitignored — never commit real secrets.

# Fleet secret — gates the OAuth / enrollment API (a node presents it to
# begin enrolling). hone-core and every hone-node must use the SAME value.
# generate:  openssl rand -hex 32
HONE_FLEET_SECRET=

# Admin token — the credential for operator/admin actions.
# generate:  openssl rand -hex 32
HONE_ADMIN_TOKEN=

# Public hostname of this hone-core. It is the SAN of the TLS certificate
# hone-core generates on first start, so nodes — which validate against the
# CA delivered at enrollment — must reach hone-core under exactly this name.
HONE_HOSTNAME=

# Host port to publish hone-core's HTTPS port on (optional; default 8000).
# hone-core always listens on 8000 inside the container — this is the host
# side of the port mapping, and the port in the default HONE_PUBLIC_URL below.
HONE_PUBLISH_PORT=8000

# Base URL nodes and operators reach hone-core at — used for the enrollment
# verification link. Optional; defaults to https://$HONE_HOSTNAME:$HONE_PUBLISH_PORT.
# Set it when behind a proxy that changes the scheme/host/port.
# HONE_PUBLIC_URL=https://core.example.com

# Gather sources to pull patchsets from — comma-separated, in priority order
# (optional). Empty / unset means every installed source. Installed sources:
# lore (the canonical patchset source — needs a public-inbox archive cloned,
# see SOURCES.md and HONE_LORE_AUTOCLONE below).
# This (and the other tunables) only *seeds* config.yaml on first start;
# thereafter config.yaml is authoritative — edit it via the operator UI's
# Settings page (ARCHITECTURE.md → Configuration).
# HONE_GATHER_SOURCES=lore

# Lore archive: opt-in background autoclone on hone-core startup. With this
# set, hone-core runs the bundled `clone` helper in a background task on
# first start, instead of waiting for the operator to run it by hand. The
# clone is bounded by --shallow-since=<Lore.since_date>, so the download
# is the window gather will actually look at (a few hundred MB to ~1 GB
# for a recent floor — see SOURCES.md). The service comes up clean either
# way; autoclone just self-bootstraps the archive in the background.
# HONE_LORE_AUTOCLONE=1

# Lore upstream URL — defaults to all-of-lore epoch 0. Point at a single
# list (smaller download) or a private mirror. Read by the `clone` helper
# and the autoclone path.
# HONE_LORE_URL=https://lore.kernel.org/linux-arm-msm/0
